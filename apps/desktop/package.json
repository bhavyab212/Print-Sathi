{
  "name": "@print-sathi/desktop",
  "version": "0.1.0",
  "description": "Print Sathi - Shopkeeper Desktop App for Windows",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
